    {
      "label": "运行 Trading 服务",
      "type": "shell",
      "command": "uv run python -m debugpy --listen 5678 --wait-for-client app/trading/trading/main.py",
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "."
          }
        }
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "detail": "启动 Trading 服务 (调试模式)"
    },
