    "version": "0.2.0",
    "configurations": [
        {
            "name": "Wallet Tracker: Remote Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/app/wallet-tracker/wallet_tracker",
                    "remoteRoot": "/app/wallet_tracker"
                }
            ],
            "justMyCode": false
        },
        {
            "name": "TG Bot: Remote Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5679
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/app/tg-bot/tg_bot",
                    "remoteRoot": "/app/tg_bot"
                }
            ],
            "justMyCode": false
        },
        {
            "name": "Trading: Remote Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5680
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/app/trading/trading",
                    "remoteRoot": "/app/trading"
                }
            ],
            "justMyCode": false
        }
    ]
}